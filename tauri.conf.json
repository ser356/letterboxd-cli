{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Letterboxd",
  "version": "0.1.0",
  "identifier": "dev.ser356.letterboxd",
  "build": {
    "beforeDevCommand": "npm --prefix ui run dev",
    "beforeBuildCommand": "npm --prefix ui run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../ui/dist"
  },
  "app": {
    "macOSPrivateApi": false,
    "windows": [
      {
        "title": "Letterboxd",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://image.tmdb.org data:; connect-src 'self' https://api.themoviedb.org https://api.letterboxd.com https://api.opensubtitles.com ipc: http://ipc.localhost; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": false
  }
}
